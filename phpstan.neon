includes:
    - vendor/nunomaduro/larastan/extension.neon

parameters:
    level: 5

    paths:
        - app
        - tests

    excludePaths:
        - app/Providers/*
        - bootstrap/cache/*
        - storage/*
        - database/migrations/*

    ignoreErrors:
        -
            message: '#Call to protected method assertDatabaseHas\(\) of class Illuminate\\Foundation\\Testing\\TestCase#'
            path: tests/Feature/ReservationTest.php
